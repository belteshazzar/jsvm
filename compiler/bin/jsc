#!/usr/bin/env node

import fs from 'node:fs/promises';

import { compileSource } from '../src/index.js';
import { encodeBundle, decodeBundle } from '../../bytecode-definition/src/index.js';

function printHelp(exitCode = 0) {
  const msg = `Usage: jsc [options]

Compiles jsvm source code from stdin or a file into bytecode.

Options:
  -f, --file <path>        Read program from file
  -o, --out <path>         Write compiled bytecode bundle
  --describe-bytecode <path>
                          Describe a bytecode bundle's imports/exports metadata
  -h, --help               Show this help

Examples:
  echo 'print(1+2);' | jsc --out ./prog.bc
  jsc --file ./prog.js --out ./prog.bc
  jsc --describe-bytecode ./prog.bc
`;
  (exitCode === 0 ? process.stdout : process.stderr).write(msg);
  process.exit(exitCode);
}

function parseArgs(argv) {
  const args = argv.slice(2);
  let filePath = null;
  let outPath = null;
  let describeBytecodePath = null;

  for (let i = 0; i < args.length; i++) {
    const arg = args[i];
    if (arg === '-h' || arg === '--help') printHelp(0);

    if (arg === '-f' || arg === '--file') {
      const value = args[i + 1];
      if (!value) {
        process.stderr.write('Missing value for --file\n');
        printHelp(2);
      }
      filePath = value;
      i++;
      continue;
    }

    if (arg === '-o' || arg === '--out') {
      const value = args[i + 1];
      if (!value) {
        process.stderr.write('Missing value for --out\n');
        printHelp(2);
      }
      outPath = value;
      i++;
      continue;
    }

    if (arg === '--describe-bytecode') {
      const value = args[i + 1];
      if (!value) {
        process.stderr.write('Missing value for --describe-bytecode\n');
        printHelp(2);
      }
      describeBytecodePath = value;
      i++;
      continue;
    }

    process.stderr.write(`Unknown argument: ${arg}\n`);
    printHelp(2);
  }

  if (describeBytecodePath && (filePath || outPath)) {
    process.stderr.write('Cannot combine --describe-bytecode with --file or --out\n');
    printHelp(2);
  }

  if (!describeBytecodePath && !outPath) {
    process.stderr.write('Missing required --out\n');
    printHelp(2);
  }

  return { filePath, outPath, describeBytecodePath };
}

function formatSpecs(specifiers, side = 'import') {
  if (!Array.isArray(specifiers) || specifiers.length === 0) return '(none)';
  return specifiers
    .map(spec => {
      if (side === 'import') {
        return spec.imported === spec.local
          ? spec.imported
          : `${spec.imported} as ${spec.local}`;
      }
      return spec.local === spec.exported
        ? spec.local
        : `${spec.local} as ${spec.exported}`;
    })
    .join(', ');
}

function printBytecodeDescription(bundle) {
  process.stdout.write('Bytecode Metadata\n');

  const imports = Array.isArray(bundle.imports) ? bundle.imports : [];
  process.stdout.write('Imports:\n');
  if (imports.length === 0) {
    process.stdout.write('  (none)\n');
  } else {
    for (const imp of imports) {
      process.stdout.write(`  - ${imp.source}: ${formatSpecs(imp.specifiers, 'import')}\n`);
    }
  }

  const exportsList = Array.isArray(bundle.exports) ? bundle.exports : [];
  const hasDefault = bundle.defaultExport !== undefined && bundle.defaultExport !== null;
  const reExports = Array.isArray(bundle.reExports) ? bundle.reExports : [];

  process.stdout.write('Exports:\n');
  if (exportsList.length === 0 && !hasDefault && reExports.length === 0) {
    process.stdout.write('  (none)\n');
    return;
  }

  if (exportsList.length > 0) {
    for (const exp of exportsList) {
      const rendered = exp.local === exp.exported ? exp.local : `${exp.local} as ${exp.exported}`;
      process.stdout.write(`  - ${rendered}\n`);
    }
  }

  if (hasDefault) {
    process.stdout.write('  - default\n');
  }

  if (reExports.length > 0) {
    for (const reExp of reExports) {
      process.stdout.write(`  - from ${reExp.source}: ${formatSpecs(reExp.specifiers, 'export')}\n`);
    }
  }
}

async function readStdin() {
  return await new Promise((resolve, reject) => {
    let data = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', chunk => {
      data += chunk;
    });
    process.stdin.on('end', () => resolve(data));
    process.stdin.on('error', reject);
  });
}

async function main() {
  const { filePath, outPath, describeBytecodePath } = parseArgs(process.argv);

  if (describeBytecodePath) {
    const buf = await fs.readFile(describeBytecodePath);
    const bundle = decodeBundle(buf);
    printBytecodeDescription(bundle);
    return;
  }

  let src;
  if (filePath) {
    src = await fs.readFile(filePath, 'utf8');
  } else {
    if (process.stdin.isTTY) printHelp(2);
    src = await readStdin();
  }

  const bundle = compileSource(src);
  const buf = encodeBundle(bundle);
  await fs.writeFile(outPath, buf);
}

main().catch(err => {
  process.stderr.write((err?.stack ?? String(err)) + '\n');
  process.exit(1);
});