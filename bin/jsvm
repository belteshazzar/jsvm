#!/usr/bin/env node

import fs from 'node:fs/promises';

import { run, compileBinary, runBundleBuffer, decodeBundle } from '../main.js';

function printHelp(exitCode = 0) {
  const msg = `Usage: jsvm [options]

Runs jsvm (safe JS subset) from stdin or a file.

Options:
  -f, --file <path>   Read program from file
  --emit-bytecode <path>
                     Compile program and write bytecode bundle
  --run-bytecode <path>
                     Execute a previously saved bytecode bundle
  --describe-bytecode <path>
                     Describe a bytecode bundle's imports/exports metadata
  -h, --help          Show this help

Examples:
  echo 'print(1+2);' | jsvm
  jsvm --file ./prog.js
  jsvm --file ./prog.js --emit-bytecode ./prog.bc
  jsvm --run-bytecode ./prog.bc
  jsvm --describe-bytecode ./prog.bc
`;
  (exitCode === 0 ? process.stdout : process.stderr).write(msg);
  process.exit(exitCode);
}

function parseArgs(argv) {
  const args = argv.slice(2);
  let filePath = null;
  let emitBytecodePath = null;
  let runBytecodePath = null;
  let describeBytecodePath = null;

  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a === '-h' || a === '--help') printHelp(0);
    if (a === '-f' || a === '--file') {
      const p = args[i + 1];
      if (!p) {
        process.stderr.write('Missing value for --file\n');
        printHelp(2);
      }
      filePath = p;
      i++;
      continue;
    }

    if (a === '--emit-bytecode') {
      const p = args[i + 1];
      if (!p) {
        process.stderr.write('Missing value for --emit-bytecode\n');
        printHelp(2);
      }
      emitBytecodePath = p;
      i++;
      continue;
    }

    if (a === '--run-bytecode') {
      const p = args[i + 1];
      if (!p) {
        process.stderr.write('Missing value for --run-bytecode\n');
        printHelp(2);
      }
      runBytecodePath = p;
      i++;
      continue;
    }

    if (a === '--describe-bytecode') {
      const p = args[i + 1];
      if (!p) {
        process.stderr.write('Missing value for --describe-bytecode\n');
        printHelp(2);
      }
      describeBytecodePath = p;
      i++;
      continue;
    }

    process.stderr.write(`Unknown argument: ${a}\n`);
    printHelp(2);
  }

  if (emitBytecodePath && runBytecodePath) {
    process.stderr.write('Cannot use --emit-bytecode and --run-bytecode together\n');
    printHelp(2);
  }

  if (describeBytecodePath && (emitBytecodePath || runBytecodePath || filePath)) {
    process.stderr.write('Cannot combine --describe-bytecode with --file, --emit-bytecode, or --run-bytecode\n');
    printHelp(2);
  }

  return { filePath, emitBytecodePath, runBytecodePath, describeBytecodePath };
}

function formatSpecs(specifiers, side = 'import') {
  if (!Array.isArray(specifiers) || specifiers.length === 0) return '(none)';
  return specifiers
    .map(spec => {
      if (side === 'import') {
        return spec.imported === spec.local
          ? spec.imported
          : `${spec.imported} as ${spec.local}`;
      }
      return spec.local === spec.exported
        ? spec.local
        : `${spec.local} as ${spec.exported}`;
    })
    .join(', ');
}

function printBytecodeDescription(bundle) {
  process.stdout.write('Bytecode Metadata\n');

  const imports = Array.isArray(bundle.imports) ? bundle.imports : [];
  process.stdout.write('Imports:\n');
  if (imports.length === 0) {
    process.stdout.write('  (none)\n');
  } else {
    for (const imp of imports) {
      process.stdout.write(`  - ${imp.source}: ${formatSpecs(imp.specifiers, 'import')}\n`);
    }
  }

  const exportsList = Array.isArray(bundle.exports) ? bundle.exports : [];
  const hasDefault = bundle.defaultExport !== undefined && bundle.defaultExport !== null;
  const reExports = Array.isArray(bundle.reExports) ? bundle.reExports : [];

  process.stdout.write('Exports:\n');
  if (exportsList.length === 0 && !hasDefault && reExports.length === 0) {
    process.stdout.write('  (none)\n');
    return;
  }

  if (exportsList.length > 0) {
    for (const exp of exportsList) {
      const rendered = exp.local === exp.exported ? exp.local : `${exp.local} as ${exp.exported}`;
      process.stdout.write(`  - ${rendered}\n`);
    }
  }

  if (hasDefault) {
    process.stdout.write('  - default\n');
  }

  if (reExports.length > 0) {
    for (const reExp of reExports) {
      process.stdout.write(`  - from ${reExp.source}: ${formatSpecs(reExp.specifiers, 'export')}\n`);
    }
  }
}

async function readStdin() {
  return await new Promise((resolve, reject) => {
    let data = '';
    process.stdin.setEncoding('utf8');
    process.stdin.on('data', chunk => (data += chunk));
    process.stdin.on('end', () => resolve(data));
    process.stdin.on('error', reject);
  });
}

async function main() {
  const { filePath, emitBytecodePath, runBytecodePath, describeBytecodePath } = parseArgs(process.argv);

  if (describeBytecodePath) {
    const buf = await fs.readFile(describeBytecodePath);
    const bundle = decodeBundle(buf);
    printBytecodeDescription(bundle);
    return;
  }

  if (runBytecodePath) {
    const buf = await fs.readFile(runBytecodePath);
    runBundleBuffer(buf, {
      onPrint: s => process.stdout.write(String(s) + '\n'),
    });
    return;
  }

  let src;
  if (filePath) {
    src = await fs.readFile(filePath, 'utf8');
  } else {
    // If nothing is piped, stdin will be a TTY. In that case, show help.
    if (process.stdin.isTTY) printHelp(2);
    src = await readStdin();
  }

  if (emitBytecodePath) {
    const buf = compileBinary(src);
    await fs.writeFile(emitBytecodePath, buf);
    return;
  }

  run(src, {
    onPrint: s => process.stdout.write(String(s) + '\n'),
  });
}

main().catch(err => {
  process.stderr.write((err?.stack ?? String(err)) + '\n');
  process.exit(1);
});
